FROM node:20-alpine

WORKDIR /app

# Install dependencies first for caching
COPY package*.json ./
RUN npm install

# In development, we don't COPY the rest of the files into the image
# because we will mount them as a volume.
# However, we need a placeholder to ensure the directory exists.
EXPOSE 3000

# Run Vite in dev mode
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
